# ============================================================================
# HASH booking engine — copy to .env.local and fill in. Never commit secrets.
# Every value here is free-tier. See README-booking.md for step-by-step setup.
# ============================================================================

# ---- Site ----
NEXT_PUBLIC_SITE_URL="https://hashops.io"

# ---- Database: Neon Postgres (free tier) ----
# Neon dashboard → your project → Connection string (pooled).
DATABASE_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# ---- Google Calendar (OAuth, free) ----
# Google Cloud console → APIs & Services → Credentials → OAuth client (Web).
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# Must match an Authorized redirect URI on the OAuth client.
GOOGLE_REDIRECT_URI="https://hashops.io/api/google/callback"
# One-time: visit /api/google/auth (signed in as the host), approve, then paste
# the refresh token it prints into here. See README-booking.md.
GOOGLE_REFRESH_TOKEN=""
# Calendar that owns availability. "primary" = the host account's main calendar.
GOOGLE_CALENDAR_ID="primary"

# ---- Email: Resend (free tier, 3k/mo) ----
RESEND_API_KEY=""
# Use a verified domain sender in production (resend.com → Domains).
EMAIL_FROM="HASH <bookings@hashops.io>"
EMAIL_REPLY_TO="info@hashops.io"

# ---- Security ----
# 32+ random chars. Generate: `openssl rand -hex 32`
BOOKING_SIGNING_SECRET=""
# Shared bearer token the cron caller must send. `openssl rand -hex 32`
CRON_SECRET=""

# ---- Availability rules (all optional — defaults live in lib/booking/config.ts) ----
BOOKING_TIMEZONE="Asia/Karachi"
BOOKING_SLOT_MINUTES="60"
BOOKING_SLOT_STEP_MINUTES="60"
BOOKING_BUFFER_MINUTES="15"
BOOKING_MIN_NOTICE_HOURS="12"
BOOKING_WINDOW_DAYS="21"
BOOKING_EXCLUDE_WEEKENDS="true"
BOOKING_HOST_NAME="Saad at HASH"
# Per-weekday working hours in BOOKING_TIMEZONE (0=Sun … 6=Sat). JSON, optional.
BOOKING_HOURS_JSON='{"1":[["10:00","17:00"]],"2":[["10:00","17:00"]],"3":[["10:00","17:00"]],"4":[["10:00","17:00"]],"5":[["10:00","17:00"]]}'

# ---- WhatsApp reminders (optional, OFF by default — email is the core) ----
WHATSAPP_ENABLED="false"
WHATSAPP_PROVIDER=""        # "cloud_api" | "twilio" (when you enable it)
WHATSAPP_TOKEN=""
WHATSAPP_PHONE_ID=""        # WhatsApp Cloud API phone number id
WHATSAPP_FROM=""            # Twilio: "whatsapp:+1..."
